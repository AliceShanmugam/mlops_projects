# Application
LOG_LEVEL=INFO
JSON_LOGS=false
LOG_DIR=/app/logs
DEBUG=false

# API
API_HOST=0.0.0.0
API_PORT=8000
API_KEY=dev-key-insecure-change-in-production

# MLFlow
MLFLOW_TRACKING_URI=http://mlflow:5000

# Airflow
AIRFLOW_WEBSERVER_URL=http://airflow:8080

# Data paths
DATA_RAW_PATH=/app/data/raw
DATA_PROCESSED_PATH=/app/data/processed
MODELS_PATH=/app/models

# Models
TFIDF_MODEL=tfidf_vectorizer.joblib
SVM_MODEL=svm.joblib

# Rate limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_PERIOD=60

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:8000,http://localhost:8080

# Airflow (pour production avec PostgreSQL)
AIRFLOW__DATABASE__SQL_ALCHEMY_CONN=sqlite:////opt/airflow/airflow.db
AIRFLOW__CORE__EXECUTOR=SequentialExecutor
AIRFLOW__CORE__LOAD_EXAMPLES=False

# DagsHub DVC
DAGSHUB_USER_TOKEN=<votre_token_dagshub>
DVC_REMOTE_URL=s3://dvc-data

API_KEY=user-key-change-in-production
ADMIN_API_KEY=admin-key-change-in-production