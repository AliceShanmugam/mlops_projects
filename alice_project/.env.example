# ============================================================
# Application
# ============================================================
LOG_LEVEL=INFO
JSON_LOGS=false
LOG_DIR=/app/logs
DEBUG=false
PROJECT_ROOT=/chemin/absolu/vers/alice_project

# ============================================================
# API — générer avec : python -c "import secrets; print(secrets.token_hex(32))"
# ============================================================
API_HOST=0.0.0.0
API_PORT=8000
API_KEY=user-key-change-in-production
ADMIN_API_KEY=admin-key-change-in-production

# ============================================================
# MLFlow → DagsHub
# ============================================================
MLFLOW_TRACKING_URI=https://dagshub.com/<username>/<repo>.mlflow

# ============================================================
# Airflow
# ============================================================
AIRFLOW_WEBSERVER_URL=http://airflow:8080
AIRFLOW_BASE_URL=http://airflow:8080/api/v1

# ============================================================
# Data paths (bind mounts Docker)
# ============================================================
DATA_RAW_DIR=/app/data/raw
DATA_PROCESSED_DIR=/app/data/processed
MODELS_PATH=/app/models

# ============================================================
# Models
# ============================================================
TFIDF_MODEL=tfidf_vectorizer.joblib
SVM_MODEL=svm.joblib
TEXT_MODEL_WEIGHT=0.7
IMAGE_MODEL_WEIGHT=0.3

# ============================================================
# Rate limiting & CORS
# ============================================================
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_PERIOD=60
CORS_ORIGINS=http://localhost:3000,http://localhost:8000,http://localhost:8080

# ============================================================
# DagsHub (DVC remote + MLFlow tracking)
# Créer un token sur : https://dagshub.com/user/settings/tokens
# ============================================================
DAGSHUB_USERNAME=<votre_username_dagshub>
DAGSHUB_USER_TOKEN=<votre_token_dagshub>
DAGSHUB_REPO=<nom_du_repo>

# ============================================================
# ChallengeData ENS (download mensuel des données)
# Compte sur : https://challengedata.ens.fr
# ============================================================
CHALLENGEDATA_USERNAME=<votre_username>
CHALLENGEDATA_PASSWORD=<votre_password>