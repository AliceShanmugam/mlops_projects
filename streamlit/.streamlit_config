[theme]
primaryColor = "#667eea"
backgroundColor = "#f0f2f6"
secondaryBackgroundColor = "#e0e0ff"
textColor = "#262730"
font = "sans serif"

[server]
headless = true
port = 8501
enableCORS = false
enableXsrfProtection = true
maxUploadSize = 100
runOnSave = true

[client]
showErrorDetails = true
toolbarMode = "minimal"

[logger]
level = "info"

[browser]
gatherUsageStats = false
serverAddress = "localhost"
